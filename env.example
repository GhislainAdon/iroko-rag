# Copy to .env (docker compose reads it automatically), then:
#   docker compose up -d web
# Pick ONE of the two options below.

# --- Option A: public API (any litellm provider) -------------------------
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=...
# MODEL=anthropic/claude-sonnet-4-6

# --- Option B: 100% local via Ollama (no key) -----------------------------
# Start it with:  docker compose --profile ollama up -d web ollama
#                 docker compose exec ollama ollama pull gemma4:e2b
# MODEL=ollama_chat/gemma4:e2b

# --- Tuning ----------------------------------------------------------------
# PAGEINDEX_MAX_CONCURRENCY=10   # lower for small Ollama servers
# OCR_LANG=fra                   # Tesseract language for scanned PDFs
